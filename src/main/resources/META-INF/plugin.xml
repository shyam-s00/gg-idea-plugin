<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>io.gopherglide.intellij.gg-idea-plugin</id>

    <name>Gopher Glide</name>

    <vendor url="https://github.com/shyam/gopher-glide">Gopher Glide</vendor>

    <description><![CDATA[
        A smart, context-aware execution and navigation layer for the Gopher-Glide (gg) load testing CLI.<br>
        Provides syntax assistance, clickable file links, and instant execution straight into the IDE's built-in terminal.
    ]]></description>

    <depends>com.intellij.modules.json</depends>
    <depends>org.jetbrains.plugins.yaml</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
            parentId="tools"
            instance="io.gopherglide.intellij.ggideaplugin.settings.GopherGlideConfigurable"
            id="io.gopherglide.intellij.ggideaplugin.settings.GopherGlideConfigurable"
            displayName="Gopher Glide"/>
    </extensions>
</idea-plugin>