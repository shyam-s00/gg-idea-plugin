<!-- Plugin Configuration File: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>dev.gopherglide.gg-plugin</id>

    <name>Gopher Glide</name>

    <vendor url="https://gopherglide.dev/">Gopher Glide</vendor>

    <description><![CDATA[
        Gopher Glide (gg) is a modern, zero-scripting API load testing and performance benchmarking CLI built in Go. Designed as a lightweight alternative to tools like k6, Gatling, or Locust, gg runs standard .http files right out of the box.<br><br>
        Generate high-concurrency traffic with a dynamic terminal UI, adjust RPS in real-time, and catch API regressions using built-in semantic JSON snapshotting. No agents, no servers, no boilerplate code.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.json</depends>
    <depends>org.jetbrains.plugins.yaml</depends>
    <depends>org.jetbrains.plugins.terminal</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationConfigurable
            parentId="tools"
            instance="dev.gopherglide.ggplugin.settings.GopherGlideConfigurable"
            id="dev.gopherglide.ggplugin.settings.GopherGlideConfigurable"
            displayName="Gopher Glide"/>

        <json.schemaProviderFactory implementation="dev.gopherglide.ggplugin.schema.GopherGlideJsonSchemaProviderFactory"/>

        <psi.referenceContributor language="yaml" implementation="dev.gopherglide.ggplugin.psi.YamlFileReferenceContributor"/>

        <runLineMarkerContributor language="yaml" implementationClass="dev.gopherglide.ggplugin.execution.GopherGlideRunLineMarkerContributor"/>

        <runLineMarkerContributor language="any" implementationClass="dev.gopherglide.ggplugin.execution.HttpGopherGlideRunLineMarkerContributor"/>

        <toolWindow id="Gopher Glide Snaps" anchor="bottom" icon="/icons/ggToolIcon.svg"
                    factoryClass="dev.gopherglide.ggplugin.snap.ui.SnapToolWindowFactory"/>
    </extensions>

    <actions>

        <action id="GopherGlide.RefreshSnaps" class="dev.gopherglide.ggplugin.snap.actions.RefreshSnapsAction" text="Refresh Snaps" icon="AllIcons.Actions.Refresh"/>
        <action id="GopherGlide.ViewSnap" class="dev.gopherglide.ggplugin.snap.actions.ViewSnapAction" text="View Snap Details" icon="AllIcons.Actions.PreviewDetails"/>
        <action id="GopherGlide.DiffSnaps" class="dev.gopherglide.ggplugin.snap.actions.DiffSnapsAction" text="Compare Snaps" icon="AllIcons.Actions.Diff"/>

        <group id="GopherGlide.Menu" text="Gopher Glide (GG)" popup="true" icon="dev.gopherglide.ggplugin.GopherGlideIcons.SidebarIcon">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
            <add-to-group group-id="EditorTabPopupMenu" anchor="last"/>

            <!-- YAML actions -->
            <action id="GopherGlide.Run" class="dev.gopherglide.ggplugin.execution.RunGopherGlideAction" text="Run" description="Run Gopher-Glide" icon="AllIcons.Actions.Execute"/>
            <action id="GopherGlide.RunAndRecordSnap" class="dev.gopherglide.ggplugin.execution.RunAndRecordSnapAction" text="Run &amp;&amp; Record" description="Run Gopher-Glide and record a snapshot" icon="AllIcons.Actions.Dump"/>

            <!-- HTTP actions -->
            <action id="GopherGlide.RunHttp" class="dev.gopherglide.ggplugin.execution.RunGopherGlideHttpAction" text="Run" description="Execute or create load test for this HTTP file" icon="AllIcons.Actions.Execute"/>
            <action id="GopherGlide.RunAndRecordSnapHttp" class="dev.gopherglide.ggplugin.execution.RunAndRecordSnapHttpAction" text="Run &amp;&amp; Record" description="Execute load test and record a snapshot for this HTTP file" icon="AllIcons.Actions.Dump"/>
        </group>
    </actions>
</idea-plugin>